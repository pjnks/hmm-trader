# Secrets
.env
.env.local
.env.*.local

# Model cache (regenerated by HMM fitting)
*.pkl

# Data cache (large OHLCV CSVs — re-fetched from Polygon API)
data_cache/

# Databases (trade logs, journals — regenerated by live traders)
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.bak*

# Optimizer outputs (large, regenerated by optimizer runs)
*_optimization_results.csv
*_results.csv
*_heatmap.html
*.csv.bak

# Generated HTML reports (regenerated by scripts)
*.html

# Logs (regenerated by live traders and optimizers)
*.log

# Generated status files (written by live traders)
*_status.json

# Presentation files (not source code)
*.pptx

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# macOS
.DS_Store

# IDE / Claude Code
.idea/
.vscode/
.claude/
*.swp
*.swo
